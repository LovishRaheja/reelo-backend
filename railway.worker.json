{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "./gradlew --no-build-cache clean buildFatJar"
  },
  "deploy": {
    "startCommand": "python3 -m pip install yt-dlp && java -jar build/libs/reelo-backend.jar worker",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}